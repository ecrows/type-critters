{
  "name": "type-critters",
  "version": "1.0.0",
  "description": "A fun typing game for kids",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "make": "electron-forge make",
    "build": "electron-packager . TypeCritters --platform=win32 --arch=x64 --out=dist --overwrite --ignore=\"(planning|dist|out|\\.git|launch\\.sh)\"",
    "web": "serve src --listen 3000 --no-clipboard"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "electron": "^33.4.0",
    "electron-packager": "^17.1.2",
    "serve": "^14.2.6"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "TypeCritters"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "win32"
          ]
        },
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "TypeCritters"
          }
        }
      ]
    }
  }
}
